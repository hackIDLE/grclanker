<!-- Keyboard shortcuts help overlay — controlled by Base.astro -->
<div id="help-backdrop" class="overlay-backdrop" aria-hidden="true"></div>
<div id="help-modal" class="overlay-modal" role="dialog" aria-modal="true" aria-label="Keyboard shortcuts">
  <div class="viewscreen rounded-lg p-6 hud-corners">
    <div class="flex items-center justify-between mb-4">
      <span class="hud-label">Keyboard Shortcuts</span>
      <div class="flex items-center gap-3">
        <span class="text-xs text-subtext0">Press <kbd>?</kbd> or <kbd>Esc</kbd> to close</span>
        <button id="help-close" type="button" class="overlay-close" aria-label="Close keyboard shortcuts">
          Close
        </button>
      </div>
    </div>
    <dl class="grid grid-cols-2 gap-x-8 gap-y-2 text-sm">
      <div class="flex items-center justify-between gap-3">
        <dt class="text-subtext1">Search site</dt>
        <dd><kbd>/</kbd> or <kbd>Cmd+K</kbd></dd>
      </div>
      <div class="flex items-center justify-between gap-3">
        <dt class="text-subtext1">Close overlay</dt>
        <dd><kbd>Esc</kbd></dd>
      </div>
      <div class="flex items-center justify-between gap-3">
        <dt class="text-subtext1">Navigate results</dt>
        <dd><kbd>&uarr;</kbd> <kbd>&darr;</kbd></dd>
      </div>
      <div class="flex items-center justify-between gap-3">
        <dt class="text-subtext1">Open selected</dt>
        <dd><kbd>Enter</kbd></dd>
      </div>
      <div class="flex items-center justify-between gap-3">
        <dt class="text-subtext1">Copy raw URL</dt>
        <dd><kbd>c</kbd> <span class="text-subtext0 text-xs">(spec pages)</span></dd>
      </div>
      <div class="flex items-center justify-between gap-3">
        <dt class="text-subtext1">Go home</dt>
        <dd><kbd>h</kbd></dd>
      </div>
      <div class="flex items-center justify-between gap-3">
        <dt class="text-subtext1">This help</dt>
        <dd><kbd>?</kbd></dd>
      </div>
    </dl>
  </div>
</div>
