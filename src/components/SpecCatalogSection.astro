---
import { RAW_BASE, groupSpecsByCategory, loadSpecs } from '../lib/specs';

interface Props {
  title?: string;
  subtitle?: string;
}

const {
  title = 'Spec Catalog',
  subtitle = 'The raw URL is the product. Copy it and feed it to your agent.',
} = Astro.props;

const specs = loadSpecs();
const categories = groupSpecsByCategory(specs);
---

<section class="viewscreen rounded-lg p-5 md:p-6 mb-8 scanlines relative">
  <div class="relative z-10">
    <div class="flex flex-col gap-2 mb-6 md:flex-row md:items-end md:justify-between">
      <div>
        <h2 class="font-semibold text-sm tracking-widest uppercase text-blue">{title}</h2>
        <p class="text-subtext0 text-sm mt-1 italic">{subtitle}</p>
      </div>
      <div class="text-[0.6875rem] font-mono uppercase tracking-[0.16em] text-subtext0">
        {specs.length} specs loaded
      </div>
    </div>

    {Object.entries(categories).map(([key, { label, specs: catSpecs }]) => (
      catSpecs.length > 0 && (
        <div class="mb-8 last:mb-0">
          <div class="spec-category-head">
            <img src={`/categories/${key}.webp`} alt="" class="spec-category-image" loading="lazy" />
            <div class="spec-category-overlay">
              <h3 class="spec-category-title">{label}</h3>
              <span class="spec-category-count">{catSpecs.length} specs</span>
            </div>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr>
                  <th scope="col" class="text-left pb-2 pr-4 hud-label !text-subtext1 !font-semibold">Spec</th>
                  <th scope="col" class="text-left pb-2 pr-4 hud-label !text-subtext1 !font-semibold hidden sm:table-cell">Vendor</th>
                  <th scope="col" class="text-left pb-2 pr-4 hud-label !text-subtext1 !font-semibold hidden md:table-cell">Updated</th>
                  <th scope="col" class="text-right pb-2 hud-label !text-subtext1 !font-semibold">Raw URL</th>
                </tr>
              </thead>
              <tbody>
                {catSpecs.map((spec) => (
                  <tr class="border-t border-surface0/40 transition-colors hover:bg-blue/[0.03]">
                    <td class="py-2.5 pr-4 align-top">
                      <a href={`/specs/${spec.slug}`} class="block font-semibold text-text hover:text-blue transition-colors leading-snug">
                        {spec.name}
                      </a>
                      <span class="mt-1 block text-xs text-subtext0 sm:hidden">{spec.vendor}</span>
                    </td>
                    <td class="py-2.5 pr-4 align-top text-subtext1 hidden sm:table-cell">{spec.vendor}</td>
                    <td class="py-2.5 pr-4 align-top text-subtext0 text-[0.6875rem] font-mono uppercase tracking-[0.08em] hidden md:table-cell">{spec.last_updated}</td>
                    <td class="py-2.5 text-right align-top">
                      <button
                        type="button"
                        class="copy-btn spec-copy-btn"
                        data-url={`${RAW_BASE}/${spec.slug}.spec.md`}
                        aria-label={`Copy raw URL for ${spec.name}`}
                      >
                        COPY
                      </button>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      )
    ))}
  </div>
</section>

<script is:inline>
  (() => {
    if (window.__grclankerSpecCatalogCopyBound) return;
    window.__grclankerSpecCatalogCopyBound = true;

    document.addEventListener('click', async function(e) {
      var btn = e.target.closest('.spec-copy-btn');
      if (!btn || !btn.dataset.url) return;

      try {
        await navigator.clipboard.writeText(btn.dataset.url);
      } catch {
        return;
      }

      btn.textContent = 'COPIED';
      btn.classList.add('copied');
      setTimeout(function() {
        btn.textContent = 'COPY';
        btn.classList.remove('copied');
      }, 1500);
    });
  })();
</script>
