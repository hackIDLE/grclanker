---
import { RAW_BASE } from '../lib/specs';

const sampleSpec = `${RAW_BASE}/aws-sec-inspector.spec.md`;

const groups = [
  {
    title: 'Terminal Agents',
    open: true,
    items: [
      { label: 'Claude Code', command: `claude "Read ${sampleSpec} and build the tool"`, preview: 'claude "Read ...spec.md and build the tool"' },
      { label: 'Codex CLI', command: `codex "Read ${sampleSpec} and build the tool"`, preview: 'codex "Read ...spec.md and build the tool"' },
      { label: 'Gemini CLI', command: `gemini "Read ${sampleSpec} and implement this spec"`, preview: 'gemini "Read ...spec.md and implement this spec"' },
      { label: 'OpenCode', command: `opencode -p "Read ${sampleSpec} and build the tool"`, preview: 'opencode -p "Read ...spec.md and build the tool"' },
      { label: 'Droid', command: `droid exec "Read ${sampleSpec} and build the tool"`, preview: 'droid exec "Read ...spec.md and build the tool"' },
      { label: 'Pi', command: `pi "Read ${sampleSpec} and build the tool"`, preview: 'pi "Read ...spec.md and build the tool"' },
      { label: 'Goose', command: `goose "Read ${sampleSpec} and build the tool"`, preview: 'goose "Read ...spec.md and build the tool"' },
      { label: 'Amp', command: `amp "Read ${sampleSpec} and build the tool"`, preview: 'amp "Read ...spec.md and build the tool"' },
      { label: 'Crush', command: `crush "Read ${sampleSpec} and build the tool"`, preview: 'crush "Read ...spec.md and build the tool"' },
    ],
  },
  {
    title: 'IDE Agents',
    open: false,
    items: [
      { label: 'Cursor / Windsurf', command: '@file aws-sec-inspector.spec.md "Implement this spec as a Go CLI tool"', preview: '@file aws-sec-inspector.spec.md "Implement this spec"' },
      { label: 'GitHub Copilot', command: '@workspace #file:aws-sec-inspector.spec.md implement this spec', preview: '@workspace #file:aws-sec-inspector.spec.md implement this spec' },
      { label: 'Cline / Roo Code', command: `Paste this URL and build the tool: ${sampleSpec}`, preview: 'Paste the raw URL into the chat' },
    ],
  },
  {
    title: 'Any Chat Interface',
    open: false,
    items: [
      {
        label: 'Claude.ai / ChatGPT / Gemini',
        command: `Here's a compliance automation spec: ${sampleSpec} — Build me the Go CLI tool it describes.`,
        preview: `Here's a spec: ...spec.md — Build me the Go CLI tool.`,
      },
    ],
  },
  {
    title: 'Programmatic',
    open: false,
    items: [
      { label: 'Pipe to any LLM', command: `curl -s ${sampleSpec} | your-agent "Build this"`, preview: 'curl -s ...spec.md | your-agent "Build this"' },
      { label: 'Clone all specs', command: 'git clone https://github.com/ethanolivertroy/grclanker.git', preview: 'git clone https://github.com/ethanolivertroy/grclanker.git' },
    ],
  },
];
---

<section class="mb-8" data-agent-commands>
  <h2 class="font-semibold text-sm tracking-widest uppercase text-blue mb-2">Use With Any Agent</h2>
  <p class="text-subtext0 text-sm mb-5 italic">Copy a command. Paste it into whatever you use.</p>

  {groups.map((group) => (
    <details class="agent-group mb-3" open={group.open}>
      <summary class="agent-group-toggle">{group.title}</summary>
      <div class="agent-group-content">
        {group.items.map((item) => (
          <div class="cmd-line" data-cmd={item.command}>
            <span class="cmd-label">{item.label}</span>
            <code>{item.preview}</code>
            <button class="cmd-copy" aria-label={`Copy command for ${item.label}`}>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="9" y="9" width="13" height="13" rx="2"></rect>
                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
              </svg>
            </button>
          </div>
        ))}
      </div>
    </details>
  ))}
</section>

<script is:inline>
(() => {
  document.querySelectorAll('[data-agent-commands] .cmd-copy').forEach((button) => {
    button.addEventListener('click', () => {
      const row = button.closest('.cmd-line');
      const command = row?.dataset.cmd;
      if (!command) return;
      navigator.clipboard.writeText(command);
      button.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#a6d189" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>';
      setTimeout(() => {
        button.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>';
      }, 1500);
    });
  });
})();
</script>
