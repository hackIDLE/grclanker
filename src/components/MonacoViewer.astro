---
interface Props {
  content: string;
}

const { content } = Astro.props;
---

<!-- Editor toolbar + Monaco container -->
<div class="editor-toolbar">
  <div class="toolbar-actions">
    <button id="tb-copy" class="toolbar-btn" title="Copy markdown">COPY</button>
    <button id="tb-wrap" class="toolbar-btn active" title="Toggle word wrap">WRAP</button>
    <button id="tb-load" class="toolbar-btn active" title="Load enhanced editor">EDITOR</button>
    <button id="tb-map" class="toolbar-btn" title="Toggle minimap" disabled>MAP</button>
  </div>
</div>

<div id="monaco-mobile-note" class="fallback-notice">
  Mobile stays in plain markdown first. Load the editor only when you need line numbers or the minimap.
</div>

<!-- Loading skeleton -->
<div id="monaco-skeleton" class="monaco-skeleton" hidden>
  <div class="skeleton-line w-3/4"></div>
  <div class="skeleton-line w-1/2"></div>
  <div class="skeleton-line w-5/6"></div>
  <div class="skeleton-line w-2/3"></div>
  <div class="skeleton-line w-4/5"></div>
  <div class="skeleton-line w-1/3"></div>
  <div class="skeleton-line w-3/4"></div>
  <div class="skeleton-line w-1/2"></div>
</div>

<!-- Editor container -->
<div id="monaco-container" style="display:none;"></div>

<!-- Fallback / default viewer -->
<pre id="monaco-fallback-pre" class="fallback-pre fallback-pre-wrap" aria-label="Raw markdown">{content}</pre>

<script>
(() => {
  const rawMarkdown = document.getElementById('monaco-fallback-pre')?.textContent ?? '';
  const container = document.getElementById('monaco-container');
  const skeleton = document.getElementById('monaco-skeleton');
  const fallbackPre = document.getElementById('monaco-fallback-pre');
  const copyBtn = document.getElementById('tb-copy');
  const wrapBtn = document.getElementById('tb-wrap');
  const loadBtn = document.getElementById('tb-load');
  const mapBtn = document.getElementById('tb-map');
  const mobileNote = document.getElementById('monaco-mobile-note');

  if (!container || !skeleton || !fallbackPre || !copyBtn || !wrapBtn || !loadBtn || !mapBtn || !mobileNote) return;

  const desktopDefaultEditor = window.matchMedia('(min-width: 768px)').matches;
  let wrapOn = true;
  let mapOn = false;
  let loading = false;
  let controller = null;
  let disposed = false;

  function syncFallbackWrap() {
    fallbackPre.classList.toggle('fallback-pre-wrap', wrapOn);
    fallbackPre.classList.toggle('fallback-pre-nowrap', !wrapOn);
  }

  syncFallbackWrap();

  copyBtn.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(rawMarkdown);
    } catch {
      return;
    }
    copyBtn.textContent = 'COPIED';
    copyBtn.classList.add('copied');
    setTimeout(() => {
      copyBtn.textContent = 'COPY';
      copyBtn.classList.remove('copied');
    }, 1500);
  });

  wrapBtn.addEventListener('click', () => {
    wrapOn = !wrapOn;
    wrapBtn.classList.toggle('active', wrapOn);
    syncFallbackWrap();
    if (controller) controller.setWrap(wrapOn);
  });

  mapBtn.addEventListener('click', () => {
    if (!controller) return;
    mapOn = !mapOn;
    mapBtn.classList.toggle('active', mapOn);
    controller.setMap(mapOn);
  });

  async function loadEditor() {
    if (disposed || controller || loading) return;
    loading = true;
    loadBtn.textContent = 'LOADING';
    loadBtn.disabled = true;
    skeleton.hidden = false;

    try {
      const { mountMonacoViewer } = await import('../lib/monaco-viewer');
      controller = await mountMonacoViewer({
        container,
        skeleton,
        fallbackPre,
        source: rawMarkdown,
        initialWrap: wrapOn,
      });
      mapBtn.disabled = false;
      loadBtn.textContent = 'READY';
      loadBtn.classList.remove('active');
      mobileNote.hidden = true;
    } catch {
      skeleton.hidden = true;
      loadBtn.textContent = 'UNAVAILABLE';
      if (desktopDefaultEditor) {
        fallbackPre.style.display = 'block';
      }
    } finally {
      loading = false;
    }
  }

  function teardown() {
    if (disposed) return;
    disposed = true;
    if (controller && typeof controller.dispose === 'function') {
      controller.dispose();
      controller = null;
    }
  }

  loadBtn.addEventListener('click', () => {
    loadEditor();
  });

  document.addEventListener('astro:before-swap', teardown, { once: true });
  window.addEventListener('pagehide', teardown, { once: true });

  if (desktopDefaultEditor) {
    mobileNote.hidden = true;
    window.setTimeout(() => {
      loadEditor();
    }, 0);
  }
})();
</script>
