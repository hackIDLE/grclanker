---
import '../styles/global.css';
import CommandPalette from '../components/CommandPalette.astro';
import ShortcutsHelp from '../components/ShortcutsHelp.astro';
import { parseFrontmatter, categoryLabels } from '../lib/specs';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Bring your own clanker. Build your own compliance. Open-source spec files for GRC compliance automation.' } = Astro.props;

// Build search data for the command palette
const specFiles = import.meta.glob('/specs/*.spec.md', { query: '?raw', import: 'default', eager: true });
const searchData = Object.entries(specFiles).map(([_, raw]) => {
  const { meta } = parseFrontmatter(raw as string);
  return {
    slug: meta.slug,
    name: meta.name,
    vendor: meta.vendor,
    category: meta.category,
    categoryLabel: categoryLabels[meta.category] || meta.category,
  };
}).sort((a, b) => a.name.localeCompare(b.name));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Social / OG -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/og-card.jpg" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/og-card.jpg" />
  </head>
  <body class="bg-base text-text font-sans min-h-screen antialiased flex flex-col">

    <!-- Skip to content -->
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[999] focus:bg-blue focus:text-crust focus:px-4 focus:py-2 focus:rounded-md focus:text-sm">
      Skip to content
    </a>

    <!-- Nav -->
    <nav class="border-b border-surface0/60 bg-mantle/80 backdrop-blur-sm sticky top-0 z-50" aria-label="Main navigation">
      <div class="max-w-content mx-auto px-6 py-3 flex items-center justify-between">
        <div class="flex items-baseline gap-2.5">
          <a href="/" class="flex items-center gap-2 text-text hover:text-blue transition-colors group">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none" class="shrink-0">
              <!-- Antenna stalk -->
              <rect x="12.5" y="0.5" width="3" height="3" rx="0.75" fill="#626880"/>
              <circle cx="14" cy="0.75" r="1.25" fill="#8caaee"/>
              <!-- Ear panels -->
              <rect x="1" y="10" width="3" height="7" rx="1" fill="#51576d"/>
              <rect x="24" y="10" width="3" height="7" rx="1" fill="#51576d"/>
              <!-- Head body -->
              <rect x="4.5" y="4" width="19" height="19" rx="3" fill="#414559" stroke="#626880" stroke-width="1"/>
              <!-- Forehead plate -->
              <rect x="7" y="6" width="14" height="4" rx="1.5" fill="#51576d"/>
              <!-- Visor band (dark inset) -->
              <rect x="6" y="11.5" width="16" height="5" rx="1" fill="#232634"/>
              <!-- Left eye -->
              <rect x="7" y="12.5" width="5" height="3" rx="1" fill="#8caaee"/>
              <!-- Right eye -->
              <rect x="16" y="12.5" width="5" height="3" rx="1" fill="#8caaee"/>
              <!-- Eye glow -->
              <rect x="7" y="12.5" width="5" height="3" rx="1" fill="#8caaee" opacity="0.3" filter="url(#glow)"/>
              <rect x="16" y="12.5" width="5" height="3" rx="1" fill="#8caaee" opacity="0.3" filter="url(#glow)"/>
              <!-- Mouth grille -->
              <rect x="9" y="18.5" width="10" height="3" rx="1" fill="#232634"/>
              <line x1="11" y1="18.5" x2="11" y2="21.5" stroke="#51576d" stroke-width="0.75"/>
              <line x1="14" y1="18.5" x2="14" y2="21.5" stroke="#51576d" stroke-width="0.75"/>
              <line x1="17" y1="18.5" x2="17" y2="21.5" stroke="#51576d" stroke-width="0.75"/>
              <!-- Chin -->
              <rect x="10" y="22" width="8" height="1.5" rx="0.5" fill="#51576d" opacity="0.5"/>
              <!-- Glow filter -->
              <defs><filter id="glow"><feGaussianBlur stdDeviation="1.5" result="blur"/><feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge></filter></defs>
            </svg>
            <span class="font-bold text-lg tracking-wider">GRCLANKER</span>
          </a>
          <a href="https://hackidle.com" class="text-overlay1 hover:text-blue text-[0.8125rem] transition-colors hidden sm:inline">by hackIDLE</a>
        </div>
        <div class="flex items-center gap-4 md:gap-6 text-sm">
          <button
            onclick="window.__openSearch && window.__openSearch()"
            class="flex items-center gap-2 text-subtext0 hover:text-blue border border-surface0/60 rounded-md px-2.5 py-1 transition-colors cursor-pointer text-xs"
            aria-label="Search specs (press / or Cmd+K)"
          >
            Search <kbd class="hidden sm:inline">/</kbd>
          </button>
          <a href="/" class="hidden sm:inline text-subtext0 hover:text-blue transition-colors">Specs</a>
          <a href="/about" class="hidden sm:inline text-subtext0 hover:text-blue transition-colors">About</a>
          <a
            href="https://github.com/ethanolivertroy/grclanker"
            target="_blank"
            rel="noopener"
            class="text-subtext0 hover:text-blue transition-colors"
            aria-label="GitHub repository"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          </a>
        </div>
      </div>
    </nav>

    <!-- Main -->
    <main id="main-content" class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-surface0/60 bg-mantle/80 relative overflow-hidden">
      <!-- Random footer image -->
      <div class="absolute inset-0 w-full h-full">
        <img id="footer-img" src="/footer/closeup.webp" alt="" class="w-full h-full object-cover object-center opacity-20" loading="lazy" />
      </div>
      <div class="max-w-content mx-auto px-6 py-3 flex items-center justify-between text-xs relative z-10">
        <div class="flex items-center gap-4 text-subtext0">
          <span>Built by <a href="https://ethantroy.dev" class="hover:text-blue">Ethan Troy</a></span>
          <a href="/" class="hover:text-blue">Specs</a>
          <a href="/about" class="hover:text-blue">About</a>
          <a href="https://github.com/ethanolivertroy/grclanker" target="_blank" rel="noopener" class="hover:text-blue">GitHub</a>
        </div>
        <span class="flex items-center gap-1.5 text-subtext0">
          <span class="led led-live"></span>
          <span class="hidden sm:inline">SYS NOMINAL</span>
        </span>
      </div>
    </footer>

    <!-- Search data for command palette -->
    <script type="application/json" id="spec-search-data" set:html={JSON.stringify(searchData)} />

    <!-- Overlays -->
    <CommandPalette />
    <ShortcutsHelp />

    <!-- Keyboard shortcuts + search JS (must be in layout, not component, for dev mode) -->
    <script is:inline>
    (function() {
      var searchOpen = false;
      var helpOpen = false;
      var selectedIndex = 0;
      var results = [];
      var specs = null;
      var prevFocus = null;

      var searchBackdrop = document.getElementById('search-backdrop');
      var searchModal = document.getElementById('search-modal');
      var searchInput = document.getElementById('search-input');
      var searchResults = document.getElementById('search-results');
      var helpBackdrop = document.getElementById('help-backdrop');
      var helpModal = document.getElementById('help-modal');
      var copyToast = document.getElementById('copy-toast');

      function getSpecs() {
        if (specs) return specs;
        var el = document.getElementById('spec-search-data');
        if (!el) return [];
        specs = JSON.parse(el.textContent);
        return specs;
      }

      function scoreSpec(spec, q) {
        var fields = [spec.name, spec.vendor, spec.categoryLabel, spec.slug];
        var best = 0;
        for (var i = 0; i < fields.length; i++) {
          var f = (fields[i] || '').toLowerCase();
          if (f === q) best = Math.max(best, 100);
          else if (f.startsWith(q)) best = Math.max(best, 80);
          else {
            var words = f.split(/[\s\-_]+/);
            for (var w = 0; w < words.length; w++) {
              if (words[w].startsWith(q)) { best = Math.max(best, 60); break; }
            }
          }
          if (best < 60 && f.indexOf(q) !== -1) best = Math.max(best, 40);
        }
        return best;
      }

      function searchSpecs(query) {
        var all = getSpecs();
        if (!query) return all.slice(0, 10);
        var q = query.toLowerCase().trim();
        if (!q) return all.slice(0, 10);
        var scored = [];
        for (var i = 0; i < all.length; i++) {
          var s = scoreSpec(all[i], q);
          if (s > 0) scored.push({ spec: all[i], score: s });
        }
        scored.sort(function(a, b) { return b.score - a.score; });
        return scored.slice(0, 10).map(function(x) { return x.spec; });
      }

      function esc(s) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

      function renderResults(items) {
        results = items;
        selectedIndex = 0;
        var html = '';
        for (var i = 0; i < items.length; i++) {
          var sp = items[i];
          html += '<li><a href="/specs/' + sp.slug + '" class="search-result' + (i===0?' active':'') + '" data-index="' + i + '">'
            + '<div class="result-name">' + esc(sp.name) + '</div>'
            + '<div class="result-meta">' + esc(sp.vendor) + ' &middot; ' + esc(sp.categoryLabel) + '</div>'
            + '</a></li>';
        }
        if (!items.length) html = '<li class="px-4 py-6 text-center"><img src="/empty-state.webp" alt="" class="w-24 h-24 mx-auto mb-3 rounded-lg object-cover"><span class="text-subtext0 text-sm block">No specs found</span></li>';
        searchResults.innerHTML = html;
      }

      function updateActive() {
        var els = searchResults.querySelectorAll('.search-result');
        for (var i = 0; i < els.length; i++) els[i].classList.toggle('active', i === selectedIndex);
        if (els[selectedIndex]) els[selectedIndex].scrollIntoView({ block: 'nearest' });
      }

      function openSearch() {
        if (helpOpen) closeHelp();
        prevFocus = document.activeElement;
        searchOpen = true;
        searchBackdrop.classList.add('open');
        searchModal.classList.add('open');
        document.body.style.overflow = 'hidden';
        searchInput.value = '';
        renderResults(searchSpecs(''));
        setTimeout(function() { searchInput.focus(); }, 50);
      }

      function closeSearch() {
        searchOpen = false;
        searchBackdrop.classList.remove('open');
        searchModal.classList.remove('open');
        document.body.style.overflow = '';
        if (prevFocus && prevFocus.focus) prevFocus.focus();
        prevFocus = null;
      }

      function openHelp() {
        if (searchOpen) closeSearch();
        prevFocus = document.activeElement;
        helpOpen = true;
        helpBackdrop.classList.add('open');
        helpModal.classList.add('open');
        document.body.style.overflow = 'hidden';
      }

      function closeHelp() {
        helpOpen = false;
        helpBackdrop.classList.remove('open');
        helpModal.classList.remove('open');
        document.body.style.overflow = '';
        if (prevFocus && prevFocus.focus) prevFocus.focus();
        prevFocus = null;
      }

      function copyRawUrl() {
        var el = document.getElementById('spec-page-data');
        if (!el) return;
        var url = el.getAttribute('data-raw-url');
        if (!url) return;
        navigator.clipboard.writeText(url);
        copyToast.classList.add('show');
        setTimeout(function() { copyToast.classList.remove('show'); }, 1500);
      }

      searchInput.addEventListener('input', function() { renderResults(searchSpecs(this.value)); });
      searchBackdrop.addEventListener('click', closeSearch);
      helpBackdrop.addEventListener('click', closeHelp);
      searchResults.addEventListener('click', function(e) { if (e.target.closest('.search-result')) closeSearch(); });
      searchResults.addEventListener('mousemove', function(e) {
        var link = e.target.closest('.search-result');
        if (link) { var idx = parseInt(link.getAttribute('data-index'),10); if (!isNaN(idx) && idx !== selectedIndex) { selectedIndex = idx; updateActive(); } }
      });

      document.addEventListener('keydown', function(e) {
        var inInput = /^(input|textarea|select)$/i.test(e.target.tagName);
        if ((e.metaKey||e.ctrlKey) && e.key==='k') { e.preventDefault(); searchOpen ? closeSearch() : openSearch(); return; }
        if (e.key==='Escape') { if (searchOpen) { closeSearch(); e.preventDefault(); } else if (helpOpen) { closeHelp(); e.preventDefault(); } return; }
        if (searchOpen) {
          if (e.key==='ArrowDown') { e.preventDefault(); selectedIndex = Math.min(selectedIndex+1, results.length-1); updateActive(); return; }
          if (e.key==='ArrowUp') { e.preventDefault(); selectedIndex = Math.max(selectedIndex-1, 0); updateActive(); return; }
          if (e.key==='Enter') { e.preventDefault(); var els = searchResults.querySelectorAll('.search-result'); if (els[selectedIndex]) { closeSearch(); window.location.href = els[selectedIndex].getAttribute('href'); } return; }
          return;
        }
        if (helpOpen) { if (e.key==='?') { closeHelp(); e.preventDefault(); } return; }
        if (inInput) return;
        if (e.key==='/') { e.preventDefault(); openSearch(); }
        else if (e.key==='?') { e.preventDefault(); openHelp(); }
        else if (e.key==='c') { copyRawUrl(); }
        else if (e.key==='h') { window.location.href = '/'; }
      });

      window.__openSearch = openSearch;
    })();
    // Randomize footer image
    (function(){
      var footers = ['/footer/walkaway.webp','/footer/skyline.webp','/footer/standby.webp','/footer/closeup.webp'];
      var img = document.getElementById('footer-img');
      if (img) img.src = footers[Math.floor(Math.random() * footers.length)];
    })();
    </script>

  </body>
</html>
