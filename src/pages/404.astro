---
import Base from '../layouts/Base.astro';

---

<Base title="Signal Lost — grclanker">
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 w-full h-full">
      <img src="/404-cockpit.webp" alt="" class="w-full h-full object-cover object-center" loading="eager" />
    </div>
    <div class="absolute inset-0 bg-gradient-to-b from-base/30 via-base/50 to-base pointer-events-none"></div>
    <div class="relative z-10 max-w-content mx-auto px-6 py-32 text-center">
      <p class="hud-label mb-4 text-red/70">Signal Lost</p>
      <h1 class="font-bold text-6xl text-text mb-4">404</h1>
      <p class="text-subtext0 mb-8">This sector is uncharted. The spec you're looking for doesn't exist.</p>
      <a
        href="/"
        class="inline-block text-sm bg-blue/10 hover:bg-blue/15 text-blue px-6 py-2.5 rounded-md border border-blue/20 transition-colors"
      >
        Return to cockpit
      </a>
    </div>
  </section>
</Base>
