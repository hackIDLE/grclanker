---
import Base from '../layouts/Base.astro';
import { loadSpecs } from '../lib/specs';

const specCount = loadSpecs().length;

const installOptions = [
  {
    key: 'curl',
    label: 'One-liner',
    command: 'curl -fsSL https://grclanker.com/install | bash',
    detail: 'Builds the companion from the repo, installs the global grclanker command, and keeps npm publishing out of the critical path.',
  },
  {
    key: 'source',
    label: 'Manual build',
    command: 'git clone https://github.com/ethanolivertroy/grclanker.git && cd grclanker/companion && npm install && npm run build && npm install -g .',
    detail: 'Use this path if you want to inspect the package before installing it globally.',
  },
  {
    key: 'dev',
    label: 'Dev mode',
    command: 'git clone https://github.com/ethanolivertroy/grclanker.git && cd grclanker/companion && npm install && npm run dev',
    detail: 'Run the Pi-based companion directly from source while you iterate on prompts, tools, or workflows.',
  },
];
---

<Base title="grclanker — Companion + Spec Catalog" description="Install the local GRC companion, launch the Pi-based dashboard, or jump into the raw spec catalog when you just need the build plans.">
  <section class="relative overflow-hidden border-b border-surface0/60">
    <div class="absolute inset-0 w-full h-full">
      <img src="/hero/cockpit.webp" alt="Retro sci-fi cockpit interface" class="w-full h-full object-cover object-center" loading="eager" />
    </div>
    <div class="absolute inset-0 bg-gradient-to-b from-base/55 via-base/80 to-base pointer-events-none"></div>

    <div class="relative z-10 max-w-content mx-auto px-6 pt-12 pb-12 md:pt-16 md:pb-16">
      <div class="grid gap-8 lg:grid-cols-[minmax(0,1.45fr)_minmax(18rem,0.95fr)] lg:items-start">
        <div class="min-w-0">
          <div class="inline-flex items-center gap-2 bg-surface0/80 border border-surface1/60 rounded-full px-4 py-1.5 mb-5">
            <span class="w-2 h-2 rounded-full bg-green"></span>
            <span class="text-subtext1 text-xs">Companion online // source-first install path ready</span>
          </div>

          <p class="hud-label mb-3">Companion Console</p>
          <h1 class="font-bold text-3xl sm:text-4xl md:text-5xl text-text leading-tight hero-text-shadow">
            Install the clanker. Run the audit.
          </h1>
          <p class="mt-4 max-w-3xl text-subtext1 text-base md:text-lg leading-relaxed">
            The homepage is for the local companion now: a Pi-based GRC console with CMVP, KEV, and EPSS tools, workflow prompts, and a startup dashboard that feels like it belongs in the cockpit.
          </p>
          <p class="mt-2 max-w-2xl text-sm text-subtext0 leading-relaxed">
            If you only want the raw build plans, the full {specCount}-spec catalog lives at <a href="/specs">/specs</a>.
          </p>

          <div id="companion-install" class="viewscreen rounded-xl scanlines relative mt-8 overflow-hidden">
            <div class="relative z-10 p-5 md:p-6">
              <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
                <div>
                  <h2 class="font-semibold text-sm tracking-widest uppercase text-blue">Install Path</h2>
                  <p class="text-subtext0 text-sm mt-1">Pick the entry point that matches how much of the package you want to inspect.</p>
                </div>
                <div class="text-[0.6875rem] font-mono uppercase tracking-[0.16em] text-subtext0">
                  Node 20+ required
                </div>
              </div>

              <div class="install-tabbar mt-5" role="tablist" aria-label="Install options">
                {installOptions.map((option, index) => (
                  <button
                    type="button"
                    class="install-tab"
                    role="tab"
                    aria-selected={index === 0 ? 'true' : 'false'}
                    data-install-tab={option.key}
                    data-active={index === 0 ? 'true' : 'false'}
                  >
                    {option.label}
                  </button>
                ))}
              </div>

              {installOptions.map((option, index) => (
                <div
                  class="install-panel mt-4"
                  data-install-panel={option.key}
                  data-active={index === 0 ? 'true' : 'false'}
                >
                  <div class="panel rounded-xl p-4 md:p-5">
                    <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
                      <div class="min-w-0">
                        <p class="hud-label !text-blue/70">Command</p>
                        <code id={`install-command-${option.key}`} class="install-command mt-3">{option.command}</code>
                      </div>
                      <button
                        type="button"
                        class="copy-btn rounded-full border border-surface0 px-3 py-1 text-[0.65rem] font-semibold tracking-[0.14em] text-blue/70 hover:text-blue hover:border-blue/30 hover:bg-blue/10 font-mono cursor-pointer transition-colors shrink-0"
                        data-install-copy={option.key}
                        data-command={option.command}
                      >
                        COPY
                      </button>
                    </div>
                    <p class="text-sm text-subtext0 mt-4 leading-relaxed">{option.detail}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <div class="mt-5 flex flex-wrap items-center gap-3 text-[0.75rem] font-mono uppercase tracking-[0.12em]">
            <a href="#operations" class="inline-flex items-center gap-2 rounded-full border border-blue/30 bg-blue/10 px-4 py-2 text-blue hover:bg-blue/15 transition-colors">
              Get Started
            </a>
            <a href="https://github.com/ethanolivertroy/grclanker" target="_blank" rel="noopener" class="inline-flex items-center gap-2 rounded-full border border-surface0 bg-mantle/70 px-4 py-2 text-subtext1 hover:text-text hover:border-surface1 transition-colors">
              GitHub
            </a>
            <a href="/specs" class="text-subtext0 hover:text-blue transition-colors">
              Need just the specs?
            </a>
          </div>
        </div>

        <aside class="viewscreen rounded-xl scanlines relative overflow-hidden">
          <div class="relative z-10 p-5 md:p-6">
            <div class="flex items-center justify-between mb-4">
              <h2 class="font-semibold text-sm tracking-widest uppercase text-blue">Startup Profile</h2>
              <span class="text-[0.6875rem] font-mono uppercase tracking-[0.16em] text-subtext0">boot sequence</span>
            </div>

            <div class="panel rounded-lg p-4 text-[0.8125rem] leading-7 text-subtext1">
              <div class="text-blue">grclanker v0.1.0</div>
              <div>12 tools online</div>
              <div>8 domain tools ready</div>
              <div>2 subagents mounted</div>
              <div>4 workflow prompts armed</div>
              <div class="text-subtext0">/investigate /audit /assess /validate</div>
            </div>

            <div class="mt-4 space-y-3 text-sm">
              <div class="flex items-start justify-between gap-3 border-b border-surface0/50 pb-3">
                <span class="hud-label !text-blue/60">domain tools</span>
                <span class="text-right text-subtext1">CMVP search, KEV lookup, EPSS scoring, ransomware checks</span>
              </div>
              <div class="flex items-start justify-between gap-3 border-b border-surface0/50 pb-3">
                <span class="hud-label !text-blue/60">session tone</span>
                <span class="text-right text-subtext1">evidence first, control mapped, direct about uncertainty</span>
              </div>
              <div class="flex items-start justify-between gap-3">
                <span class="hud-label !text-blue/60">spec standby</span>
                <span class="text-right text-subtext1">{specCount} raw build plans still available at /specs</span>
              </div>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <div class="max-w-content mx-auto px-6 py-8 md:py-10 space-y-8">
    <section id="operations" class="grid gap-5 lg:grid-cols-[minmax(0,1.1fr)_minmax(18rem,0.9fr)]">
      <div class="viewscreen rounded-xl scanlines relative overflow-hidden">
        <div class="relative z-10 p-5 md:p-6">
          <div class="flex flex-col gap-2 md:flex-row md:items-end md:justify-between">
            <div>
              <h2 class="font-semibold text-sm tracking-widest uppercase text-blue">Operational Surface</h2>
              <p class="text-subtext0 text-sm mt-1">What the companion answers without leaving the terminal.</p>
            </div>
            <div class="text-[0.6875rem] font-mono uppercase tracking-[0.16em] text-subtext0">
              Pi + local prompts
            </div>
          </div>

          <div class="grid gap-6 mt-6 md:grid-cols-[minmax(0,1.2fr)_minmax(14rem,0.8fr)]">
            <div class="panel rounded-lg p-4">
              <p class="hud-label !text-blue/60 mb-3">Primary Instruments</p>
              <div class="space-y-3 text-sm">
                <div class="flex items-start justify-between gap-4 border-b border-surface0/50 pb-3">
                  <span class="text-text">cmvp_search_modules</span>
                  <span class="text-right text-subtext0">active FIPS validations by vendor, module, or cert ID</span>
                </div>
                <div class="flex items-start justify-between gap-4 border-b border-surface0/50 pb-3">
                  <span class="text-text">cmvp_search_historical</span>
                  <span class="text-right text-subtext0">expired or revoked module history for drift checks</span>
                </div>
                <div class="flex items-start justify-between gap-4 border-b border-surface0/50 pb-3">
                  <span class="text-text">cmvp_search_in_process</span>
                  <span class="text-right text-subtext0">pipeline visibility for modules still in validation</span>
                </div>
                <div class="flex items-start justify-between gap-4 border-b border-surface0/50 pb-3">
                  <span class="text-text">cmvp_get_module</span>
                  <span class="text-right text-subtext0">certificate-level detail when you already have the ID</span>
                </div>
                <div class="flex items-start justify-between gap-4 border-b border-surface0/50 pb-3">
                  <span class="text-text">kevs_search</span>
                  <span class="text-right text-subtext0">CISA KEV lookups with EPSS enrichment</span>
                </div>
                <div class="flex items-start justify-between gap-4 border-b border-surface0/50 pb-3">
                  <span class="text-text">kevs_get_epss</span>
                  <span class="text-right text-subtext0">30-day exploit probability for one or more CVEs</span>
                </div>
                <div class="flex items-start justify-between gap-4 border-b border-surface0/50 pb-3">
                  <span class="text-text">kevs_recent</span>
                  <span class="text-right text-subtext0">recently added exploited vulns for fast triage</span>
                </div>
                <div class="flex items-start justify-between gap-4">
                  <span class="text-text">kevs_check_ransomware</span>
                  <span class="text-right text-subtext0">KEV entries with known ransomware campaign use</span>
                </div>
              </div>
            </div>

            <div class="panel rounded-lg p-4">
              <p class="hud-label !text-blue/60 mb-3">Why it exists</p>
              <div class="space-y-3 text-sm leading-relaxed text-subtext1">
                <p>The companion is for fast evidence gathering and posture triage when you do not want to bounce between CMVP, KEV, EPSS, and framework notes by hand.</p>
                <p>It stays direct: certificate IDs, CVE IDs, due dates, exploit probability, and control references instead of vague security prose.</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="space-y-5">
        <div class="viewscreen rounded-xl scanlines relative overflow-hidden">
          <div class="relative z-10 p-5">
            <h2 class="font-semibold text-sm tracking-widest uppercase text-blue">Workflow Deck</h2>
            <div class="mt-4 space-y-3 text-sm">
              <div class="panel rounded-lg p-3">
                <div class="text-text">/investigate</div>
                <div class="text-subtext0 mt-1">Trace crypto status, KEVs, EPSS, and ransomware linkage for a subject.</div>
              </div>
              <div class="panel rounded-lg p-3">
                <div class="text-text">/audit</div>
                <div class="text-subtext0 mt-1">Map gathered evidence against the requested framework and rank remediation.</div>
              </div>
              <div class="panel rounded-lg p-3">
                <div class="text-text">/assess</div>
                <div class="text-subtext0 mt-1">Produce a posture readout with confidence, major risks, and next actions.</div>
              </div>
              <div class="panel rounded-lg p-3">
                <div class="text-text">/validate</div>
                <div class="text-subtext0 mt-1">Answer the narrow FIPS question cleanly: active, expired, in process, or absent.</div>
              </div>
            </div>
          </div>
        </div>

        <div class="viewscreen rounded-xl scanlines relative overflow-hidden">
          <div class="relative z-10 p-5">
            <h2 class="font-semibold text-sm tracking-widest uppercase text-blue">Spec Handoff</h2>
            <p class="mt-3 text-sm text-subtext1 leading-relaxed">
              The companion handles live GRC workflows. The raw spec library stays separate so you can still grab the Markdown and feed it to any coding agent without installing anything.
            </p>
            <div class="panel rounded-lg p-4 mt-4">
              <p class="hud-label !text-blue/60 mb-2">Catalog status</p>
              <div class="text-text text-sm">{specCount} spec files // raw URLs // agent-agnostic prompts</div>
              <a href="/specs" class="inline-flex items-center gap-2 mt-4 rounded-full border border-surface0 px-4 py-2 text-[0.75rem] font-mono uppercase tracking-[0.12em] text-subtext1 hover:text-blue hover:border-blue/30 transition-colors">
                Open /specs
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>
</Base>

<script is:inline>
(() => {
  const tabs = Array.from(document.querySelectorAll('[data-install-tab]'));
  const panels = Array.from(document.querySelectorAll('[data-install-panel]'));

  function setActive(key) {
    tabs.forEach((tab) => {
      const active = tab.dataset.installTab === key;
      tab.dataset.active = active ? 'true' : 'false';
      tab.setAttribute('aria-selected', active ? 'true' : 'false');
    });

    panels.forEach((panel) => {
      panel.dataset.active = panel.dataset.installPanel === key ? 'true' : 'false';
    });
  }

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => setActive(tab.dataset.installTab));
  });

  document.querySelectorAll('[data-install-copy]').forEach((button) => {
    button.addEventListener('click', () => {
      navigator.clipboard.writeText(button.dataset.command);
      const original = button.textContent;
      button.textContent = 'COPIED';
      button.classList.add('copied');
      setTimeout(() => {
        button.textContent = original;
        button.classList.remove('copied');
      }, 1500);
    });
  });
})();
</script>
