            <code><span class="text-blue">droid exec</span> <span class="text-peach">"Read ...spec.md and build the tool"</span></code>
            <button class="cmd-copy" aria-label="Copy command"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg></button>
          </div>
          <div class="cmd-line" data-cmd={`pi "Read ${RAW_BASE}/aws-sec-inspector.spec.md and build the tool"`}>
            <span class="cmd-label">Pi</span>
            <code><span class="text-blue">pi</span> <span class="text-peach">"Read ...spec.md and build the tool"</span></code>
            <button class="cmd-copy" aria-label="Copy command"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg></button>
          </div>
          <div class="cmd-line" data-cmd={`goose "Read ${RAW_BASE}/aws-sec-inspector.spec.md and build the tool"`}>
            <span class="cmd-label">Goose</span>
            <code><span class="text-blue">goose</span> <span class="text-peach">"Read ...spec.md and build the tool"</span></code>
            <button class="cmd-copy" aria-label="Copy command"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg></button>
          </div>
          <div class="cmd-line" data-cmd={`amp "Read ${RAW_BASE}/aws-sec-inspector.spec.md and build the tool"`}>
            <span class="cmd-label">Amp</span>
            <code><span class="text-blue">amp</span> <span class="text-peach">"Read ...spec.md and build the tool"</span></code>
            <button class="cmd-copy" aria-label="Copy command"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg></button>
          </div>
          <div class="cmd-line" data-cmd={`crush "Read ${RAW_BASE}/aws-sec-inspector.spec.md and build the tool"`}>
            <span class="cmd-label">Crush</span>
            <code><span class="text-blue">crush</span> <span class="text-peach">"Read ...spec.md and build the tool"</span></code>
            <button class="cmd-copy" aria-label="Copy command"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg></button>
          </div>
        </div>
      </details>

      <details class="agent-group mb-3">
        <summary class="agent-group-toggle">IDE Agents</summary>
        <div class="agent-group-content">
          <div class="cmd-line" data-cmd='@file aws-sec-inspector.spec.md "Implement this spec as a Go CLI tool"'>
            <span class="cmd-label">Cursor / Windsurf</span>
            <code><span class="text-blue">@file</span> aws-sec-inspector.spec.md <span class="text-peach">"Implement this spec"</span></code>
            <button class="cmd-copy" aria-label="Copy command"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg></button>
          </div>
          <div class="cmd-line" data-cmd="@workspace #file:aws-sec-inspector.spec.md implement this spec">
            <span class="cmd-label">GitHub Copilot</span>
            <code><span class="text-blue">@workspace</span> #file:aws-sec-inspector.spec.md implement this spec</code>
            <button class="cmd-copy" aria-label="Copy command"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg></button>
          </div>
          <div class="cmd-line" data-cmd={`Paste this URL and build the tool: ${RAW_BASE}/aws-sec-inspector.spec.md`}>
            <span class="cmd-label">Cline / Roo Code</span>
            <code>Paste the raw URL into the chat</code>
            <button class="cmd-copy" aria-label="Copy command"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg></button>
          </div>
        </div>
      </details>

      <details class="agent-group mb-3">
        <summary class="agent-group-toggle">Any Chat Interface</summary>
        <div class="agent-group-content">
          <div class="cmd-line" data-cmd={`Here's a compliance automation spec: ${RAW_BASE}/aws-sec-inspector.spec.md — Build me the Go CLI tool it describes.`}>
            <span class="cmd-label">Claude.ai / ChatGPT / Gemini</span>
            <code>Here's a spec: <span class="text-lavender">...spec.md</span> — <span class="text-peach">Build me the Go CLI tool.</span></code>
            <button class="cmd-copy" aria-label="Copy command"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg></button>
          </div>
        </div>
      </details>

      <details class="agent-group mb-3">
        <summary class="agent-group-toggle">Programmatic</summary>
        <div class="agent-group-content">
          <div class="cmd-line" data-cmd={`curl -s ${RAW_BASE}/aws-sec-inspector.spec.md | your-agent "Build this"`}>
            <span class="cmd-label">Pipe to any LLM</span>
            <code><span class="text-blue">curl</span> -s <span class="text-lavender">...spec.md</span> | your-agent <span class="text-peach">"Build this"</span></code>
            <button class="cmd-copy" aria-label="Copy command"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg></button>
          </div>
          <div class="cmd-line" data-cmd="git clone https://github.com/ethanolivertroy/grclanker.git">
            <span class="cmd-label">Clone all specs</span>
            <code><span class="text-blue">git clone</span> https://github.com/ethanolivertroy/grclanker.git</code>
            <button class="cmd-copy" aria-label="Copy command"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg></button>
          </div>
        </div>
      </details>
    </section>

    <!-- ═══ ROADMAP ═══ -->
    <section class="mb-10 border-t border-surface0/60 pt-6 md:pt-8">
      <h2 class="font-semibold text-sm tracking-widest uppercase text-blue mb-3">What's Next</h2>
      <p class="text-subtext0 text-sm">More specs. More tools. That's the plan. Check <a href="https://github.com/ethanolivertroy/grclanker">the repo</a> for updates.</p>
    </section>


  </div>
</Base>

<script is:inline>
// Typewriter
(function(){
  var terms = ['FedRAMP','CMMC','SOC 2','PCI-DSS','NIST 800-53','DISA STIG','CIS Benchmarks','your agent'];
  var el = document.getElementById('typewriter');
  var cur = document.getElementById('cursor');
  if (!el) return;
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) { el.textContent = terms[0]; return; }
  var ti = 0, ci = 0, del = false;
  function tick() {
    var term = terms[ti];
    if (!del) {
      ci++;
      el.textContent = term.slice(0, ci);
      if (ci >= term.length) { del = true; setTimeout(tick, 1800); return; }
      setTimeout(tick, 60);
    } else {
      ci--;
      el.textContent = term.slice(0, ci);
      if (ci <= 0) { del = false; ti = (ti + 1) % terms.length; setTimeout(tick, 300); return; }
      setTimeout(tick, 35);
    }
  }
  tick();
})();
// Status pill
(function(){
  var msgs = ['Mapping controls...','Collecting evidence...','Generating reports...','Validating configs...','Scanning posture...'];
  var el = document.getElementById('status-text');
  if (!el) return;
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
  var i = 0;
  setInterval(function(){ i = (i+1) % msgs.length; el.textContent = msgs[i]; }, 3000);
})();
// Hero copy
(function(){
  var btn = document.getElementById('hero-copy');
  if (!btn) return;
  btn.addEventListener('click', function(){
    navigator.clipboard.writeText(btn.dataset.cmd);
    btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#a6d189" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
    setTimeout(function(){ btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>'; }, 1500);
  });
})();
// Cmd line copy buttons
(function(){
  document.querySelectorAll('.cmd-copy').forEach(function(btn){
    btn.addEventListener('click', function(){
      var cmd = btn.closest('.cmd-line').dataset.cmd;
      navigator.clipboard.writeText(cmd);
      btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#a6d189" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
      setTimeout(function(){ btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>'; }, 1500);
    });
  });
})();
// Randomize images
(function(){
  function pick(arr) { return arr[Math.floor(Math.random() * arr.length)]; }
  var heroes = ['/hero/command-center.webp','/hero/cockpit.webp','/hero/holographic.webp','/hero/assembly.webp'];
  var h = document.getElementById('hero-img'); if (h) h.src = pick(heroes);
})();
</script>
