---
import { existsSync } from 'node:fs';
import { resolve } from 'node:path';
import Base from '../layouts/Base.astro';
import { loadSpecs } from '../lib/specs';

const specCount = loadSpecs().length;

const installCommands = [
  { key: 'curl', label: 'curl', command: 'curl -fsSL https://grclanker.com/install | bash' },
  { key: 'npm', label: 'npm', command: 'npm install -g @grclanker/cli' },
  { key: 'bun', label: 'bun', command: 'bun install -g @grclanker/cli' },
];

const terminalExamples = [
  {
    command: 'grclanker "what is the CMVP certificate for BoringCrypto?"',
    description: 'Resolve the exact validation record and answer with the cert, standard, and status.',
  },
  {
    command: 'grclanker investigate "CVE-2024-3094"',
    description: 'Trace KEV status, EPSS likelihood, and ransomware linkage in one pass.',
  },
  {
    command: 'grclanker "read specs/aws-sec-inspector.spec.md and build the tool"',
    description: 'Use the repo’s own spec files as build inputs instead of treating them like a separate product.',
  },
];

const workflowCards = [
  {
    command: '/investigate',
    color: 'text-sapphire',
    description: 'Trace crypto status, KEVs, EPSS, and ransomware linkage for a module, vendor, product, or CVE.',
  },
  {
    command: '/audit',
    color: 'text-yellow',
    description: 'Map gathered evidence against the requested framework and classify what is satisfied, partial, absent, or unverifiable.',
  },
  {
    command: '/assess',
    color: 'text-peach',
    description: 'Produce an evidence-backed posture readout with top risks, confidence notes, and remediation order.',
  },
  {
    command: '/validate',
    color: 'text-green',
    description: 'Answer the narrow FIPS question cleanly: active, historical, in process, or absent.',
  },
];

const releaseFacts = [
  {
    label: 'Local-first setup',
    detail: 'Run grclanker setup. Choose local Ollama + Gemma 4 or save a hosted provider and model.',
  },
  {
    label: 'What ships in 0.0.1',
    detail: 'Sixty-one tools, two agents, and four structured workflows around CMVP, KEV, EPSS, official FedRAMP GitHub-grounded 20x and Rev5 lookups, FedRAMP readiness, ADS package planning, starter bundles, portable public trust-center site generation, read-only Duo, Okta, GitHub, and Google Workspace compliance assessments, optional Google Workspace CLI operator evidence workflows, Vanta access checks, SCF crosswalks, trestle-backed OSCAL workspaces, and posture triage.',
  },
  {
    label: 'Specs as inputs',
    detail: `Point grclanker at any of the ${specCount} repo specs when you want it to build one.`,
  },
];

const brandFrames = [
  {
    image: '/hero/assembly.webp',
    eyebrow: 'Specs in',
    title: 'Feed a spec to any agent. It has enough context to build.',
  },
  {
    image: '/hero/holographic.webp',
    eyebrow: 'Terminal-first',
    title: 'Evidence gathering stays in your terminal.',
  },
  {
    image: '/about-clanker.webp',
    eyebrow: 'Local-first',
    title: 'Your data stays on your machine. Or choose a hosted path.',
  },
];

const screenshotCandidates = [
  '/hero/grclanker-terminal.png',
  '/hero/grclanker-terminal.webp',
  '/hero/grclanker-terminal.jpg',
];

const previewImage = screenshotCandidates.find((candidate) =>
  existsSync(resolve(process.cwd(), 'public', candidate.slice(1))),
);
---

<Base title="grclanker: Put a Clanker on Your Compliance" description="CMVP certificates, KEV feeds, EPSS scores, framework mappings. One terminal session. Nothing leaves your machine.">
  <section class="relative overflow-hidden border-b border-surface0/60">
    <div class="absolute inset-0 w-full h-full">
      <img src="/hero/command-center.webp" alt="Clanker command center" class="w-full h-full object-cover object-center" loading="eager" />
    </div>
    <div class="absolute inset-0 bg-gradient-to-b from-base/65 via-base/84 to-base pointer-events-none"></div>

    <div class="relative z-10 max-w-content mx-auto px-6 pt-14 pb-18 md:pt-20 md:pb-24">
      <section class="hero-stack">
        <div class="max-w-4xl text-center hero-copy-block">
          <h1 class="font-bold text-4xl sm:text-5xl lg:text-6xl text-text leading-tight hero-text-shadow">
            Your compliance evidence is scattered.<br />Put a clanker on it.
          </h1>
          <p class="mx-auto mt-5 max-w-2xl text-base md:text-lg text-subtext1 leading-relaxed italic hero-copy-lede">
            CMVP certificates, KEV feeds, EPSS scores, framework mappings. One terminal session. Nothing leaves your machine.
          </p>
        </div>

        <div class="hero-install-panel">
          <div class="hero-install-shell">
            <div class="hero-install-toggle-row" role="tablist" aria-label="Install methods">
              {installCommands.map((entry, index) => (
                <button
                  type="button"
                  class:list={[
                    'hero-install-toggle',
                    index === 0 ? 'is-active' : '',
                  ]}
                  data-hero-install-tab={entry.key}
                  data-command={entry.command}
                  role="tab"
                  aria-selected={index === 0 ? 'true' : 'false'}
                  tabindex={index === 0 ? 0 : -1}
                >
                  {entry.label}
                </button>
              ))}
            </div>

            <button
              id="hero-install-command"
              type="button"
              class="hero-install-command group"
              data-command={installCommands[0].command}
              aria-label="Copy install command"
            >
              <span id="hero-install-command-text" class="hero-install-command-text">{installCommands[0].command}</span>
              <svg id="hero-install-copy" class="hero-install-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <rect x="9" y="9" width="13" height="13" rx="2"></rect>
                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
              </svg>
              <svg id="hero-install-check" class="hero-install-icon hidden text-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M20 6L9 17l-5-5"></path>
              </svg>
            </button>
          </div>

          <div class="hero-action-row">
            <a href="/docs/getting-started/installation" class="hero-primary-link">
              Get Started
            </a>
            <a href="https://github.com/hackIDLE/grclanker" target="_blank" rel="noopener" class="hero-secondary-link">
              GitHub
            </a>
          </div>

          <p class="hero-support-copy">
            Need just the skills? <a href="/docs/getting-started/installation#skills-only">Install the skills-only bundle</a>.
          </p>
        </div>
      </section>
    </div>
  </section>

  <section class="hero-preview-section">
    <div class="max-w-content mx-auto px-6">
      <div class="hero-preview-shell">
        {previewImage ? (
          <img src={previewImage} alt="GRC Clanker terminal screenshot" class="hero-preview-image" loading="eager" />
        ) : (
          <div class="hero-preview-fallback hero-surface-panel">
            <div class="hero-preview-body">
              <div class="docs-note">
                <strong class="text-text">Current release.</strong>
                <span class="text-subtext1">The homepage only shows a terminal preview when there is a real runtime capture in <code>public/hero/grclanker-terminal.*</code>. Until then, this panel stays descriptive instead of pretending to be the UI.</span>
              </div>

              <div class="hero-preview-grid mt-4">
                <div>
                  <p class="hud-label !text-subtext1 mb-3">Current release</p>
                  <div class="space-y-3 text-sm">
                    {releaseFacts.slice(0, 2).map((item) => (
                      <div class="grid gap-2">
                        <span class="text-blue">{item.label}</span>
                        <span class="text-subtext1">{item.detail}</span>
                      </div>
                    ))}
                  </div>
                </div>
                <div>
                  <p class="hud-label !text-subtext1 mb-3">What it already does</p>
                  <div class="space-y-3 text-sm">
                    {workflowCards.slice(0, 2).map((item) => (
                      <div class="grid gap-2">
                        <span class="text-text">{item.command}</span>
                        <span class="text-subtext1">{item.description}</span>
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </div>
        )}
      </div>
    </div>
  </section>

  <div class="max-w-content mx-auto px-6 pt-5 pb-8 md:pt-7 md:pb-10 space-y-8">
    <section class="hero-brand-rail" aria-label="Clanker brand frames">
      {brandFrames.map((frame, index) => (
        <article class="hero-brand-card">
          <img
            src={frame.image}
            alt=""
            class="hero-brand-image"
            loading="lazy"
            data-home-rail-image={index}
          />
          <div class="hero-brand-overlay">
            <span class="hero-brand-eyebrow">{frame.eyebrow}</span>
            <p class="hero-brand-title">{frame.title}</p>
          </div>
        </article>
      ))}
    </section>

    <section class="viewscreen rounded-xl scanlines relative overflow-hidden hero-briefing">
      <div class="relative z-10 p-5 md:p-6">
        <div class="hero-briefing-top">
          <div>
            <h2 class="font-semibold text-sm tracking-widest uppercase text-blue">What You Ask → What It Does</h2>
            <p class="text-subtext0 text-sm mt-1 italic">What 0.0.1 does well.</p>
          </div>
          <div class="hero-briefing-version">0.0.1 experimental</div>
        </div>

        <div class="hero-briefing-grid">
          <div class="hero-briefing-main">
            <div class="hero-summary-list">
              {terminalExamples.map((item) => (
                <div class="hero-summary-item">
                  <div class="hero-summary-command">{item.command}</div>
                  <div class="hero-summary-copy">{item.description}</div>
                </div>
              ))}
            </div>
          </div>

          <aside class="hero-briefing-side" aria-label="Release details">
            <p class="hero-briefing-kicker">
              First release. Tight scope. More is coming.
            </p>

            <div class="hero-fact-list">
              {releaseFacts.map((item) => (
                <div class="hero-fact-row">
                  <div class="hero-fact-label">{item.label}</div>
                  <div class="hero-fact-body">{item.detail}</div>
                </div>
              ))}
            </div>
          </aside>
        </div>
      </div>
    </section>

    <section class="hero-image-break" aria-label="Clanker ambient frame">
      <img
        id="home-break-image"
        src="/mid-break.webp"
        alt=""
        class="hero-image-break-image"
        loading="lazy"
      />
      <div class="hero-image-break-overlay">
        <span class="hero-image-break-pill">Evidence first // controls mapped // build from specs</span>
      </div>
    </section>

    <section class="viewscreen rounded-xl scanlines relative overflow-hidden">
      <div class="relative z-10 p-5 md:p-6">
        <div class="flex flex-col gap-2 md:flex-row md:items-end md:justify-between">
          <div>
            <h2 class="font-semibold text-sm tracking-widest uppercase text-blue">Workflow Deck</h2>
            <p class="text-subtext0 text-sm mt-1 italic">Four structured workflows. Pick one, stay on it.</p>
          </div>
          <div class="text-[0.6875rem] font-mono uppercase tracking-[0.16em] text-subtext0">
            /investigate /audit /assess /validate
          </div>
        </div>

        <div class="workflow-grid">
          {workflowCards.map((item) => (
            <div class="workflow-row">
              <div class:list={[item.color]}>{item.command}</div>
              <div class="text-subtext0 text-sm mt-2 leading-relaxed">{item.description}</div>
            </div>
          ))}
        </div>
      </div>
    </section>
  </div>
</Base>

<script is:inline>
(() => {
  function initHeroInstall() {
    const toggles = Array.from(document.querySelectorAll('[data-hero-install-tab]'));
    const commandButton = document.getElementById('hero-install-command');
    const commandText = document.getElementById('hero-install-command-text');
    const copyIcon = document.getElementById('hero-install-copy');
    const checkIcon = document.getElementById('hero-install-check');

    if (!toggles.length || !commandButton || !commandText || !copyIcon || !checkIcon) return;

    toggles.forEach((toggle) => {
      if (toggle.dataset.bound === 'true') return;
      toggle.dataset.bound = 'true';

      toggle.addEventListener('click', () => {
        activateTab(toggle);
      });

      toggle.addEventListener('keydown', (e) => {
        const idx = toggles.indexOf(toggle);
        let next;
        if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
          e.preventDefault();
          next = toggles[(idx + 1) % toggles.length];
        } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
          e.preventDefault();
          next = toggles[(idx - 1 + toggles.length) % toggles.length];
        } else if (e.key === 'Home') {
          e.preventDefault();
          next = toggles[0];
        } else if (e.key === 'End') {
          e.preventDefault();
          next = toggles[toggles.length - 1];
        }
        if (next) { next.focus(); activateTab(next); }
      });
    });

    function activateTab(toggle) {
      const nextCommand = toggle.dataset.command;
      if (!nextCommand) return;

      commandButton.setAttribute('data-command', nextCommand);
      commandText.textContent = nextCommand;

      toggles.forEach((item) => {
        const active = item === toggle;
        item.classList.toggle('is-active', active);
        item.setAttribute('aria-selected', active ? 'true' : 'false');
        item.setAttribute('tabindex', active ? '0' : '-1');
      });
    }

    if (commandButton.dataset.bound !== 'true') {
      commandButton.dataset.bound = 'true';

      commandButton.addEventListener('click', () => {
        const command = commandButton.getAttribute('data-command');
        if (!command) return;

        navigator.clipboard.writeText(command).then(() => {
          copyIcon.classList.add('hidden');
          checkIcon.classList.remove('hidden');
          setTimeout(() => {
            copyIcon.classList.remove('hidden');
            checkIcon.classList.add('hidden');
          }, 1600);
        });
      });
    }
  }

  function shuffle(array) {
    const next = array.slice();
    for (let index = next.length - 1; index > 0; index -= 1) {
      const swapIndex = Math.floor(Math.random() * (index + 1));
      [next[index], next[swapIndex]] = [next[swapIndex], next[index]];
    }
    return next;
  }

  function initHomepageAssets() {
    const railImages = Array.from(document.querySelectorAll('[data-home-rail-image]'));
    const breakImage = document.getElementById('home-break-image');

    if (railImages.length) {
      const pool = shuffle([
        '/hero/assembly.webp',
        '/hero/holographic.webp',
        '/about-clanker.webp',
        '/mid-break.webp',
        '/footer/closeup.webp',
        '/footer/skyline.webp',
      ]);

      railImages.forEach((image, index) => {
        if (!(image instanceof HTMLImageElement)) return;
        image.src = pool[index % pool.length];
      });
    }

    if (breakImage instanceof HTMLImageElement) {
      const breakPool = [
        '/mid-break.webp',
        '/footer/walkaway.webp',
        '/footer/standby.webp',
        '/hero/command-center.webp',
      ];
      breakImage.src = breakPool[Math.floor(Math.random() * breakPool.length)];
    }
  }

  initHeroInstall();
  initHomepageAssets();
  document.addEventListener('astro:after-swap', initHeroInstall);
  document.addEventListener('astro:after-swap', initHomepageAssets);
})();
</script>
