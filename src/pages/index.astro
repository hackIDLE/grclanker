---
import Base from '../layouts/Base.astro';

import { parseFrontmatter, categoryLabels, RAW_BASE, type SpecMeta } from '../lib/specs';

const specFiles = import.meta.glob('/specs/*.spec.md', { query: '?raw', import: 'default', eager: true });

const specs = Object.entries(specFiles).map(([path, raw]) => {
  const { meta } = parseFrontmatter(raw as string);
  return meta;
}).sort((a, b) => a.name.localeCompare(b.name));

const categories: Record<string, { label: string; specs: SpecMeta[] }> = {};
Object.entries(categoryLabels).forEach(([key, label]) => {
  categories[key] = { label, specs: [] };
});

specs.forEach(spec => {
  if (categories[spec.category]) {
    categories[spec.category].specs.push(spec);
  }
});

const HERO_CMD = `claude "Read ${RAW_BASE}/aws-sec-inspector.spec.md and build the tool"`;
---

<Base title="grclanker — GRC Compliance Automation Specs">

  <!-- ═══ HERO ═══ -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 w-full h-full">
      <img id="hero-img" src="/hero/command-center.webp" alt="Clanker robots at work" class="w-full h-full object-cover object-center" loading="eager" />
    </div>
    <div class="absolute inset-0 bg-gradient-to-b from-base/60 via-base/75 to-base pointer-events-none"></div>
    <div class="relative z-10 max-w-content mx-auto px-6 pt-12 md:pt-16 pb-16 md:pb-20 text-center">

      <!-- Status pill -->
      <div class="inline-flex items-center gap-2 bg-surface0/80 border border-surface1/60 rounded-full px-4 py-1.5 mb-4 md:mb-6">
        <span class="w-2 h-2 rounded-full bg-green" id="status-dot"></span>
        <span class="text-subtext1 text-xs" id="status-text">Mapping controls...</span>
      </div>

      <!-- Typewriter heading -->
      <h1 class="text-2xl sm:text-4xl md:text-6xl font-bold text-text leading-tight mb-4 md:mb-6 min-h-[2.5rem] sm:min-h-[3rem] md:min-h-[4.5rem] hero-text-shadow">
        Specs for <span class="text-blue">&gt;</span> <span class="text-lavender" id="typewriter"></span><span class="text-blue" id="cursor">&#9608;</span>
      </h1>

      <!-- Subtitle -->
      <p class="text-subtext1 text-xl md:text-2xl leading-relaxed max-w-2xl mx-auto mb-3 font-medium">
        Bring your own clanker. Build your own compliance.
      </p>
      <p class="text-subtext0 text-sm md:text-base max-w-xl mx-auto mb-8">
        Open-source spec files for GRC compliance automation. 31 specs. Any agent.
      </p>

      <!-- Hero install command + badge -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-6 max-w-3xl mx-auto mb-4">
        <img src="/badges/audited-by-clanker.webp" alt="Audited by Clanker" class="w-28 h-28 sm:w-32 sm:h-32 rounded-full shrink-0" loading="eager" />
        <div class="cmd-hero flex-1 w-full">
          <code id="hero-cmd-text"><span class="text-blue">claude</span> <span class="text-peach">"Read {RAW_BASE}/aws-sec-inspector.spec.md and build the tool"</span></code>
          <button class="cmd-hero-copy" id="hero-copy" data-cmd={HERO_CMD} aria-label="Copy command to clipboard">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
          </button>
        </div>
      </div>

      <p class="text-subtext0 text-sm">Browse the specs below.</p>
    </div>
  </section>

  <div class="max-w-content mx-auto px-6">

    <!-- ═══ SPEC CATALOG ═══ -->
    <section class="viewscreen rounded-lg p-5 md:p-6 mb-8 scanlines relative">
      <div class="relative z-10">
        <div class="flex items-center justify-between mb-6">
          <h2 class="font-semibold text-sm tracking-widest uppercase text-blue">Spec Catalog</h2>
          <span class="text-xs text-subtext0 font-mono">{specs.length} LOADED</span>
        </div>

        {Object.entries(categories).map(([key, { label, specs: catSpecs }]) => (
          catSpecs.length > 0 && (
            <div class="mb-8 last:mb-0">
              <div class="relative h-12 md:h-14 rounded-t-lg overflow-hidden mb-2.5">
                <img src={`/categories/${key}.webp`} alt="" class="w-full h-full object-cover" loading="lazy" />
                <div class="absolute inset-0 bg-gradient-to-r from-base/80 via-base/40 to-base/80"></div>
                <h3 class="absolute inset-0 flex items-center px-4 font-semibold text-[0.6875rem] text-text uppercase tracking-[0.18em] z-10">
                  <span class="w-1.5 h-1.5 bg-blue/60 rounded-full mr-2"></span>
                  {label}
                </h3>
              </div>
              <div class="overflow-x-auto">
                <table class="w-full text-sm">
                  <thead>
                    <tr>
                      <th scope="col" class="text-left pb-2 pr-4 hud-label !text-blue/50 !font-semibold">Spec</th>
                      <th scope="col" class="text-left pb-2 pr-4 hud-label !text-blue/50 !font-semibold hidden sm:table-cell">Vendor</th>
                      <th scope="col" class="text-left pb-2 pr-4 hud-label !text-blue/50 !font-semibold hidden md:table-cell">Updated</th>
                      <th scope="col" class="text-right pb-2 hud-label !text-blue/50 !font-semibold">Raw URL</th>
                    </tr>
                  </thead>
                  <tbody>
                    {catSpecs.map(spec => (
                      <tr class="border-t border-surface0/40 transition-colors hover:bg-blue/[0.03]">
                        <td class="py-3 pr-4 align-top">
                          <a href={`/specs/${spec.slug}`} class="block font-semibold text-text hover:text-blue transition-colors leading-snug">
                            {spec.name}
                          </a>
                          <span class="mt-1 block text-xs text-subtext0 sm:hidden">{spec.vendor}</span>
                        </td>
                        <td class="py-3 pr-4 align-top text-subtext1 hidden sm:table-cell">{spec.vendor}</td>
                        <td class="py-3 pr-4 align-top text-subtext0 text-[0.6875rem] font-mono uppercase tracking-[0.08em] hidden md:table-cell">{spec.last_updated}</td>
                        <td class="py-3 text-right align-top">
                          <button
                            class="copy-btn inline-flex items-center rounded-full border border-surface0 px-3 py-1 text-[0.65rem] font-semibold tracking-[0.14em] text-blue/70 hover:text-blue hover:border-blue/30 hover:bg-blue/10 font-mono cursor-pointer transition-colors"
                            data-url={`${RAW_BASE}/${spec.slug}.spec.md`}
                            aria-label={`Copy raw URL for ${spec.name}`}
                            onclick="let b=this;navigator.clipboard.writeText(b.dataset.url);b.textContent='COPIED';b.classList.add('copied');setTimeout(()=>{b.textContent='COPY';b.classList.remove('copied')},1500)"
                          >
                            COPY
                          </button>
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>
          )
        ))}
      </div>
    </section>

    <!-- ═══ USE WITH ANY AGENT ═══ -->
    <section class="mb-8">
      <h2 class="font-semibold text-sm tracking-widest uppercase text-blue mb-2">Use With Any Agent</h2>
      <p class="text-subtext0 text-sm mb-5">Copy a command. Paste it into whatever you use.</p>

      <details class="agent-group mb-3" open>
        <summary class="agent-group-toggle">Terminal Agents</summary>
        <div class="agent-group-content">
          <div class="cmd-line" data-cmd={`claude "Read ${RAW_BASE}/aws-sec-inspector.spec.md and build the tool"`}>
            <span class="cmd-label">Claude Code</span>
            <code><span class="text-blue">claude</span> <span class="text-peach">"Read ...spec.md and build the tool"</span></code>
            <button class="cmd-copy" aria-label="Copy command"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg></button>
          </div>
          <div class="cmd-line" data-cmd={`codex "Read ${RAW_BASE}/aws-sec-inspector.spec.md and build the tool"`}>
            <span class="cmd-label">Codex CLI</span>
            <code><span class="text-blue">codex</span> <span class="text-peach">"Read ...spec.md and build the tool"</span></code>
            <button class="cmd-copy" aria-label="Copy command"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg></button>
          </div>
          <div class="cmd-line" data-cmd={`gemini "Read ${RAW_BASE}/aws-sec-inspector.spec.md and implement this spec"`}>
            <span class="cmd-label">Gemini CLI</span>
            <code><span class="text-blue">gemini</span> <span class="text-peach">"Read ...spec.md and implement this spec"</span></code>
            <button class="cmd-copy" aria-label="Copy command"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg></button>
          </div>
          <div class="cmd-line" data-cmd={`opencode -p "Read ${RAW_BASE}/aws-sec-inspector.spec.md and build the tool"`}>
            <span class="cmd-label">OpenCode</span>
            <code><span class="text-blue">opencode</span> -p <span class="text-peach">"Read ...spec.md and build the tool"</span></code>
            <button class="cmd-copy" aria-label="Copy command"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg></button>
          </div>
          <div class="cmd-line" data-cmd={`droid exec "Read ${RAW_BASE}/aws-sec-inspector.spec.md and build the tool"`}>
