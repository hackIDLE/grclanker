---
import Base from '../../layouts/Base.astro';
import SpecCatalogSection from '../../components/SpecCatalogSection.astro';
import { RAW_BASE, loadSpecs } from '../../lib/specs';

const specs = loadSpecs();
const heroCommand = `curl -O ${RAW_BASE}/aws-sec-inspector.spec.md`;
---

<Base title="Specs — grclanker" description="Browse raw GRC automation specs, copy the URL, and hand the file to any agent.">
  <section class="relative overflow-hidden border-b border-surface0/60">
    <div class="absolute inset-0 w-full h-full">
      <img src="/hero/holographic.webp" alt="Spec catalog cockpit display" class="w-full h-full object-cover object-center" loading="eager" />
    </div>
    <div class="absolute inset-0 bg-gradient-to-b from-base/55 via-base/78 to-base pointer-events-none"></div>

    <div class="relative z-10 max-w-content mx-auto px-6 pt-14 pb-14 md:pt-18 md:pb-18">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="font-bold text-3xl sm:text-4xl md:text-5xl text-text leading-tight hero-text-shadow">
          Bring your own clanker. Build your own compliance.
        </h1>
      </div>

      <div class="mt-8 max-w-3xl mx-auto">
        <div class="cmd-hero">
          <code id="spec-hero-command">{heroCommand}</code>
          <button class="cmd-hero-copy" id="spec-hero-copy" data-cmd={heroCommand} aria-label="Copy raw spec command">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="9" y="9" width="13" height="13" rx="2"></rect>
              <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
            </svg>
          </button>
        </div>
      </div>
    </div>
  </section>

  <div class="max-w-content mx-auto px-6 py-8 md:py-10">
    <SpecCatalogSection />

    <section class="page-image-break mb-8" aria-label="Specs ambient frame">
      <img
        src="/footer/closeup.webp"
        alt=""
        class="page-image-break-image"
        loading="lazy"
      />
      <div class="page-image-break-overlay">
        <span class="page-image-break-pill">Raw markdown in // agent output out</span>
      </div>
    </section>

    <section class="viewscreen rounded-xl scanlines relative overflow-hidden">
      <div class="relative z-10 p-5 md:p-6 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
        <div class="max-w-2xl">
          <h2 class="font-semibold text-sm tracking-widest uppercase text-blue mb-2">Use With Any Agent</h2>
          <p class="text-subtext1 text-sm leading-relaxed italic">
            The long-form command examples live in the docs now so the catalog can stay focused on raw spec discovery and copy flow.
          </p>
        </div>
        <a href="/docs/specs/using-specs-as-inputs" class="spec-action-btn spec-action-btn-primary self-start md:self-auto">
          Open docs
        </a>
      </div>
    </section>
  </div>
</Base>

<script is:inline>
(() => {
  const button = document.getElementById('spec-hero-copy');
  if (!button) return;
  button.addEventListener('click', () => {
    navigator.clipboard.writeText(button.dataset.cmd);
    button.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#a6d189" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>';
    setTimeout(() => {
      button.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>';
    }, 1500);
  });
})();
</script>
