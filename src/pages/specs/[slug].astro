---
import Base from '../../layouts/Base.astro';
import MonacoViewer from '../../components/MonacoViewer.astro';

import { parseFrontmatter, categoryLabels, RAW_BASE, type SpecMeta } from '../../lib/specs';

const specFiles = import.meta.glob('/specs/*.spec.md', { query: '?raw', import: 'default', eager: true });

export function getStaticPaths() {
  const files = import.meta.glob('/specs/*.spec.md', { query: '?raw', import: 'default', eager: true });
  return Object.entries(files)
    .map(([path, raw]) => {
      const rawStr = raw as string;
      const match = rawStr.match(/^---\n([\s\S]*?)\n---\n([\s\S]*)$/);
      if (!match) return null;
      const slugMatch = match[1].match(/slug:\s*["']?([^"'\n]+)["']?/);
      if (!slugMatch) return null;
      return { params: { slug: slugMatch[1].trim() } };
    })
    .filter((entry): entry is { params: { slug: string } } => entry !== null);
}

const { slug } = Astro.params;
const entry = Object.entries(specFiles).find(([_, raw]) => {
  const { meta } = parseFrontmatter(raw as string);
  return meta.slug === slug;
});

if (!entry) {
  return Astro.redirect('/404');
}

const { meta, content } = parseFrontmatter(entry[1] as string);
const rawMarkdown = content.trim();

const rawUrl = `${RAW_BASE}/${meta.slug}.spec.md`;
const githubUrl = `https://github.com/hackIDLE/grclanker/blob/main/specs/${meta.slug}.spec.md`;
const editUrl = `https://github.com/hackIDLE/grclanker/edit/main/specs/${meta.slug}.spec.md`;
---

<Base title={`${meta.name} — grclanker`} description={`Compliance automation spec for ${meta.vendor}. ${meta.name}.`}>
  <div class="max-w-content mx-auto px-4 py-6 sm:px-6 sm:py-8">

    <!-- Spec page data for keyboard shortcuts + markdown copy -->
    <div id="spec-page-data" data-raw-url={rawUrl} data-slug={meta.slug} class="hidden"></div>

    <div class="viewscreen rounded-lg mb-6 overflow-hidden">
      <div class="px-4 py-5 sm:px-6 sm:py-6 flex flex-col gap-5 lg:flex-row lg:items-start lg:justify-between">
        <div class="min-w-0">
          <p class="text-[0.6875rem] font-mono uppercase tracking-[0.18em] text-subtext1 mb-2">{meta.slug}.spec.md</p>
          <h1 class="font-bold text-2xl md:text-3xl text-text leading-tight">{meta.name}</h1>
          <div class="mt-3 flex flex-wrap gap-2">
            <span class="inline-flex items-center rounded-full border border-blue/20 bg-blue/[0.06] px-2.5 py-1 text-[0.6875rem] font-mono uppercase tracking-[0.12em] text-blue">
              {meta.vendor}
            </span>
            <span class="inline-flex items-center rounded-full border border-teal/20 bg-teal/[0.06] px-2.5 py-1 text-[0.6875rem] font-mono uppercase tracking-[0.12em] text-teal">
              {categoryLabels[meta.category] || meta.category}
            </span>
            <span class="inline-flex items-center rounded-full border border-surface0 bg-crust/70 px-2.5 py-1 text-[0.6875rem] font-mono uppercase tracking-[0.12em] text-subtext0">
              {meta.language}
            </span>
            <span class="inline-flex items-center rounded-full border border-surface0 bg-crust/70 px-2.5 py-1 text-[0.6875rem] font-mono uppercase tracking-[0.12em] text-subtext0">
              v{meta.version}
            </span>
            <span class="inline-flex items-center rounded-full border border-surface0 bg-crust/70 px-2.5 py-1 text-[0.6875rem] font-mono uppercase tracking-[0.12em] text-subtext0">
              {meta.last_updated}
            </span>
          </div>
        </div>

        <div class="flex flex-wrap items-center gap-2 lg:max-w-[18rem] lg:justify-end">
          <button
            type="button"
            class="copy-btn spec-action-btn spec-action-btn-primary"
            data-url={rawUrl}
            data-label="COPY URL"
            aria-label={`Copy raw URL for ${meta.name}`}
          >
            COPY URL
          </button>
          <a
            href={rawUrl}
            download
            class="spec-action-btn"
          >
            Download
          </a>
          <a
            href={githubUrl}
            target="_blank"
            rel="noopener"
            class="spec-action-btn"
          >
            GitHub
          </a>
          <a
            href={editUrl}
            target="_blank"
            rel="noopener"
            class="spec-action-link"
          >
            Suggest edit
          </a>
        </div>
      </div>
    </div>

    <div class="viewscreen rounded-lg scanlines relative min-w-0 overflow-hidden">
      <div class="relative z-10">
        <MonacoViewer content={rawMarkdown} />
      </div>
    </div>

  </div>
</Base>

<script is:inline>
  (() => {
    if (window.__grclankerSpecPageCopyBound) return;
    window.__grclankerSpecPageCopyBound = true;

    document.addEventListener('click', async function(e) {
      var btn = e.target.closest('.spec-action-btn-primary.copy-btn');
      if (!btn || !btn.dataset.url) return;
      var label = btn.dataset.label || 'COPY URL';

      try {
        await navigator.clipboard.writeText(btn.dataset.url);
      } catch {
        return;
      }

      btn.textContent = 'COPIED';
      btn.classList.add('copied');
      setTimeout(function() {
        btn.textContent = label;
        btn.classList.remove('copied');
      }, 1500);
    });
  })();
</script>
