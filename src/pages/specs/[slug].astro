---
import Base from '../../layouts/Base.astro';

import { marked } from 'marked';
import { parseFrontmatter, categoryLabels, RAW_BASE, type SpecMeta } from '../../lib/specs';

const specFiles = import.meta.glob('/specs/*.spec.md', { query: '?raw', import: 'default', eager: true });

export function getStaticPaths() {
  const files = import.meta.glob('/specs/*.spec.md', { query: '?raw', import: 'default', eager: true });
  return Object.entries(files)
    .map(([path, raw]) => {
      const rawStr = raw as string;
      const match = rawStr.match(/^---\n([\s\S]*?)\n---\n([\s\S]*)$/);
      if (!match) return null;
      const slugMatch = match[1].match(/slug:\s*["']?([^"'\n]+)["']?/);
      if (!slugMatch) return null;
      return { params: { slug: slugMatch[1].trim() } };
    })
    .filter((entry): entry is { params: { slug: string } } => entry !== null);
}

const { slug } = Astro.params;
const entry = Object.entries(specFiles).find(([_, raw]) => {
  const { meta } = parseFrontmatter(raw as string);
  return meta.slug === slug;
});

if (!entry) {
  return Astro.redirect('/404');
}

const { meta, content } = parseFrontmatter(entry[1] as string);
const rawMarkdown = content.trim();
const htmlContent = await marked(rawMarkdown);

const rawUrl = `${RAW_BASE}/${meta.slug}.spec.md`;
const githubUrl = `https://github.com/ethanolivertroy/grclanker/blob/main/specs/${meta.slug}.spec.md`;
const editUrl = `https://github.com/ethanolivertroy/grclanker/edit/main/specs/${meta.slug}.spec.md`;
---

<Base title={`${meta.name} — grclanker`} description={`Compliance automation spec for ${meta.vendor}. ${meta.name}.`}>
  <div class="max-w-content mx-auto px-6 py-8">

    <!-- Spec page data for keyboard shortcuts + markdown copy -->
    <div id="spec-page-data" data-raw-url={rawUrl} data-slug={meta.slug} class="hidden"></div>
    <script type="application/json" id="spec-markdown-data" set:html={JSON.stringify(rawMarkdown)} />

    <!-- Breadcrumb -->
    <div class="text-sm text-subtext0 mb-6 font-mono">
      <a href="/" class="hover:text-blue">GRCLANKER</a>
      <span class="mx-2 text-surface2">/</span>
      <span class="text-subtext0">{meta.slug}</span>
    </div>

    <!-- Title bar -->
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-8">
      <div>
        <h1 class="font-bold text-2xl text-text">{meta.name}</h1>
        <p class="text-subtext0 text-sm mt-1">{meta.vendor} &middot; {categoryLabels[meta.category] || meta.category}</p>
      </div>
      <div class="flex items-center gap-2 flex-wrap">
        <button
          class="copy-btn text-xs bg-blue/10 hover:bg-blue/15 text-blue px-3 py-1.5 rounded-md border border-blue/20 font-semibold tracking-wide transition-all cursor-pointer"
          data-url={rawUrl}
          onclick="let b=this;navigator.clipboard.writeText(b.dataset.url);b.textContent='COPIED';b.classList.add('copied');setTimeout(()=>{b.textContent='COPY URL';b.classList.remove('copied')},1500)"
        >
          COPY URL
        </button>
        <button
          class="copy-btn text-xs bg-mantle hover:bg-surface0/60 text-subtext1 px-3 py-1.5 rounded-md border border-surface0 font-semibold tracking-wide transition-all cursor-pointer"
          id="copy-md-btn"
          onclick="let b=this;var md=document.getElementById('spec-markdown-data');if(md){navigator.clipboard.writeText(JSON.parse(md.textContent));b.textContent='COPIED';b.classList.add('copied');setTimeout(()=>{b.textContent='COPY MD';b.classList.remove('copied')},1500)}"
        >
          COPY MD
        </button>
        <a
          href={rawUrl}
          download
          class="text-xs bg-mantle hover:bg-surface0/60 text-subtext0 px-3 py-1.5 rounded-md border border-surface0 transition-colors"
        >
          Download
        </a>
        <a
          href={githubUrl}
          target="_blank"
          rel="noopener"
          class="text-xs bg-mantle hover:bg-surface0/60 text-subtext0 px-3 py-1.5 rounded-md border border-surface0 transition-colors"
        >
          GitHub
        </a>
      </div>
    </div>

    <div class="lg:grid lg:grid-cols-[13rem_1fr] lg:gap-6">
      <!-- Left panel: metadata -->
      <aside class="hidden lg:block">
        <div class="panel rounded-lg p-5 sticky top-20">
          <dl class="space-y-3 text-sm">
            <div>
              <dt class="text-subtext0 text-[0.6875rem] font-mono mb-0.5">VENDOR</dt>
              <dd class="text-text">{meta.vendor}</dd>
            </div>
            <div>
              <dt class="text-subtext0 text-[0.6875rem] font-mono mb-0.5">CATEGORY</dt>
              <dd class="text-subtext1 text-xs">{categoryLabels[meta.category] || meta.category}</dd>
            </div>
            <div class="flex gap-6">
              <div>
                <dt class="text-subtext0 text-[0.6875rem] font-mono mb-0.5">LANG</dt>
                <dd class="text-text uppercase font-mono text-sm">{meta.language}</dd>
              </div>
              <div>
                <dt class="text-subtext0 text-[0.6875rem] font-mono mb-0.5">VER</dt>
                <dd class="text-text font-mono text-sm">{meta.version}</dd>
              </div>
            </div>
            <div>
              <dt class="text-subtext0 text-[0.6875rem] font-mono mb-0.5">UPDATED</dt>
              <dd class="text-subtext1 text-xs font-mono">{meta.last_updated}</dd>
            </div>
          </dl>

          <hr class="hud-divider my-4" />

          <a
            href={editUrl}
            target="_blank"
            rel="noopener"
            class="block text-xs text-subtext0 hover:text-blue transition-colors font-mono"
          >
            Suggest edit
          </a>
        </div>
      </aside>

      <!-- Main viewscreen: spec content -->
      <div class="viewscreen rounded-lg p-6 md:p-8 scanlines relative min-w-0">
        <!-- Mobile metadata -->
        <div class="lg:hidden mb-6 pb-4 border-b border-surface0 flex flex-wrap gap-4 text-xs font-mono">
          <span class="text-subtext0">VENDOR: <span class="text-subtext1">{meta.vendor}</span></span>
          <span class="text-subtext0">LANG: <span class="text-subtext1 uppercase">{meta.language}</span></span>
          <span class="text-subtext0">UPDATED: <span class="text-subtext1">{meta.last_updated}</span></span>
        </div>

        <div class="relative z-10 spec-content" set:html={htmlContent} />
      </div>
    </div>

    <!-- Mobile actions -->
    <div class="lg:hidden mt-6 flex flex-wrap gap-2">
      <button
        class="copy-btn text-xs bg-blue/10 hover:bg-blue/15 text-blue px-3 py-1.5 rounded-md border border-blue/20 cursor-pointer transition-all"
        data-url={rawUrl}
        onclick="let b=this;navigator.clipboard.writeText(b.dataset.url);b.textContent='COPIED';b.classList.add('copied');setTimeout(()=>{b.textContent='COPY URL';b.classList.remove('copied')},1500)"
      >
        COPY URL
      </button>
      <button
        class="copy-btn text-xs bg-mantle hover:bg-surface0/60 text-subtext1 px-3 py-1.5 rounded-md border border-surface0 cursor-pointer transition-all"
        onclick="let b=this;var md=document.getElementById('spec-markdown-data');if(md){navigator.clipboard.writeText(JSON.parse(md.textContent));b.textContent='COPIED';b.classList.add('copied');setTimeout(()=>{b.textContent='COPY MD';b.classList.remove('copied')},1500)}"
      >
        COPY MD
      </button>
      <a href={rawUrl} download class="text-xs bg-mantle text-subtext0 px-3 py-1.5 rounded-md border border-surface0">Download</a>
      <a href={githubUrl} target="_blank" rel="noopener" class="text-xs bg-mantle text-subtext0 px-3 py-1.5 rounded-md border border-surface0">GitHub</a>
    </div>

  </div>
</Base>
